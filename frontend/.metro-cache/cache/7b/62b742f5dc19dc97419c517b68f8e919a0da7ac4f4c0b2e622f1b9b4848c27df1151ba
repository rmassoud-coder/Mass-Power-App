d, vin, plate_number, make, model, year, created_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?)`, [id, customerId, vin, plateNumber, make, model, year || null, now]);\n    return {\n      id,\n      customer_id: customerId,\n      vin,\n      plate_number: plateNumber,\n      make,\n      model,\n      year,\n      created_at: now\n    };\n  }\n  async function updateVehicle(id, vin, plateNumber, make, model, year) {\n    const db = await getDb();\n    await db.runAsync(`UPDATE vehicles SET vin = ?, plate_number = ?, make = ?, model = ?, year = ? WHERE id = ?`, [vin, plateNumber, make, model, year || null, id]);\n  }\n  async function deleteVehicle(id) {\n    const db = await getDb();\n    await db.runAsync(`DELETE FROM services WHERE vehicle_id = ?`, [id]);\n    await db.runAsync(`DELETE FROM vehicles WHERE id = ?`, [id]);\n  }\n\n  // ============ Service Operations ============\n  async function createService(vehicleId, serviceDescription, additionalInfo, cost, isPaid, dashLights, oilReminder) {\n    const db = await getDb();\n    const vehicle = await db.getFirstAsync(`SELECT * FROM vehicles WHERE id = ?`, [vehicleId]);\n    if (!vehicle) {\n      throw new Error('Vehicle not found');\n    }\n    const id = generateId();\n    const now = new Date().toISOString();\n    const d = dashLights || EMPTY_DASH_LIGHTS;\n    const o = oilReminder || EMPTY_OIL_REMINDER;\n    await db.runAsync(`INSERT INTO services (id, vehicle_id, customer_id, service_description, additional_info, cost, is_paid, service_date, created_at, dash_abs, dash_check_engine, dash_brake, dash_airbag, dash_immobilizer, current_mileage, next_service_date, next_service_mileage) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`, [id, vehicleId, vehicle.customer_id, serviceDescription, additionalInfo || null, cost, isPaid ? 1 : 0, now, now, d.abs ? 1 : 0, d.check_engine ? 1 : 0, d.brake ? 1 : 0, d.airbag ? 1 : 0, d.immobilizer ? 1 : 0, o.currentMileage, o.nextServiceDate, o.nextServiceMileage]);\n    return {\n      id,\n      vehicle_id: vehicleId,\n      customer_id: vehicle.customer_id,\n      service_description: serviceDescription,\n      additional_info: additionalInfo,\n      cost,\n      is_paid: isPaid,\n      service_date: now,\n      created_at: now,\n      dash_abs: d.abs,\n      dash_check_engine: d.check_engine,\n      dash_brake: d.brake,\n      dash_airbag: d.airbag,\n      dash_immobilizer: d.immobilizer,\n      current_mileage: o.currentMileage,\n      next_service_date: o.nextServiceDate,\n      next_service_mileage: o.nextServiceMileage\n    };\n  }\n  async function updateService(id, serviceDescription, additionalInfo, cost, isPaid, dashLights, oilReminder) {\n    const db = await getDb();\n    const d = dashLights || EMPTY_DASH_LIGHTS;\n    const o = oilReminder || EMPTY_OIL_REMINDER;\n    await db.runAsync(`UPDATE services SET service_description = ?, additional_info = ?, cost = ?, is_paid = ?, dash_abs = ?, dash_check_engine = ?, dash_brake = ?, dash_airbag = ?, dash_immobilizer = ?, current_mileage = ?, next_service_date = ?, next_service_mileage = ? WHERE id = ?`, [serviceDescription, additionalInfo || null, cost, isPaid ? 1 : 0, d.abs ? 1 : 0, d.check_engine ? 1 : 0, d.brake ? 1 : 0, d.airbag ? 1 : 0, d.immobilizer ? 1 : 0, o.currentMileage, o.nextServiceDate, o.nextServiceMileage, id]);\n  }\n  async function deleteService(id) {\n    const db = await getDb();\n    await db.runAsync(`DELETE FROM services WHERE id = ?`, [id]);\n  }\n\n  // ============ Report ============\n  async function getReport(startDate, endDate, mobile, vin, plate, unpaidOnly) {\n    const db = await getDb();\n    const conditions = [];\n    const params = [];\n    if (startDate) {\n      conditions.push('s.service_date >= ?');\n      params.push(startDate);\n    }\n    if (endDate) {\n      conditions.push('s.service_date <= ?');\n      params.push(endDate);\n    }\n    if (mobile) {\n      conditions.push('c.mobile_number LIKE ?');\n      params.push(`%${mobile}%`)