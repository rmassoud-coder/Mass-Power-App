{
  "expo": {
    "name": "Garage Service",
    "slug": "garage-service",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "garage-service",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "extra": {
      "backendUrl": "${EXPO_PUBLIC_BACKEND_URL}"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.garageservice.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#2563eb"
      },
      "package": "com.garageservice.app",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#2563eb"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
